# Optional: override the WebSocket backend URL.
# When unset, the client connects to the same origin that served the page,
# which works in production behind a reverse proxy and in dev via the Vite
# proxy configured in vite.config.ts.
# VITE_WS_BASE_URL=wss://api.example.com

# Clerk Publishable Key — required only when you want auth gating on /host.
# Find it in your Clerk dashboard → API keys → React.
# Without this, the app runs in fully-anonymous mode (no auth UI shown).
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
